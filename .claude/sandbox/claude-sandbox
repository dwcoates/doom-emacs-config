#!/usr/bin/env bash
# claude-sandbox — run Claude Code inside the doom-sandbox Docker sandbox.
# All arguments are forwarded transparently to the claude invocation.
# Usage: claude-sandbox [claude-args...]
#
# Permission mode is auto-detected from the repo path:
#   ChessCom repos → --permission-mode auto
#   all others     → --dangerously-skip-permissions
# Override by passing --permission-mode or --dangerously-skip-permissions explicitly.
#
# Extra mounts: edit .claude/sandbox/mounts (JSON with "defaults" and "custom" arrays).
#
# GitHub CLI auth: set CLAUDE_SANDBOX_GH_AUTH=1 in your shell to enable GH_TOKEN passthrough.

set -euo pipefail

GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) \
  || { echo "claude-sandbox: not in a git repo" >&2; exit 1; }
DIRNAME=$(basename "$GIT_ROOT")
IMAGE=$(tr -d '[:space:]' < "$GIT_ROOT/.claude/sandbox/image")

# Check if caller already specified a permission mode
HAS_PERM_FLAG=false
for arg in "$@"; do
  if [[ "$arg" == "--permission-mode" || "$arg" == "--dangerously-skip-permissions" ]]; then
    HAS_PERM_FLAG=true
    break
  fi
done

if [[ "$HAS_PERM_FLAG" == "false" ]]; then
  if [[ "$GIT_ROOT" == *"ChessCom"* ]]; then
    PERM_ARGS=(--permission-mode auto)
  else
    PERM_ARGS=(--dangerously-skip-permissions)
  fi
else
  PERM_ARGS=()
fi

# If running from a worktree, also mount the main repo at its host path so
# git's stored absolute references (in .git/worktrees/) resolve inside the container.
WORKTREE_MOUNTS=()
GIT_COMMON_DIR=$(git -C "$GIT_ROOT" rev-parse --git-common-dir 2>/dev/null || true)
if [[ -n "$GIT_COMMON_DIR" && "$GIT_COMMON_DIR" != ".git" ]]; then
  MAIN_REPO_ROOT=$(cd "$GIT_ROOT" && cd "$GIT_COMMON_DIR/.." && pwd)
  if [[ "$MAIN_REPO_ROOT" != "$GIT_ROOT" ]]; then
    WORKTREE_MOUNTS+=(-v "$MAIN_REPO_ROOT:$MAIN_REPO_ROOT")
  fi
fi

# Inject GH_TOKEN into the container when CLAUDE_SANDBOX_GH_AUTH=1 is set.
# Token is sourced from ~/.config/gh/token, falling back to $GITHUB_TOKEN.
# Also injects git identity and a credential helper so git operations work.
GH_TOKEN_ENV=()
GIT_AUTH_ENV=()
if [[ -n "${CLAUDE_SANDBOX_GH_AUTH:-}" ]]; then
  GH_TOKEN_FILE="$HOME/.config/gh/token"
  if [[ -f "$GH_TOKEN_FILE" ]]; then
    GH_TOKEN_ENV=(-e "GH_TOKEN=$(cat "$GH_TOKEN_FILE")")
  elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
    GH_TOKEN_ENV=(-e "GH_TOKEN=$GITHUB_TOKEN")
  else
    echo "claude-sandbox: warning: CLAUDE_SANDBOX_GH_AUTH is set but no token found (tried ~/.config/gh/token and \$GITHUB_TOKEN)" >&2
  fi

  if [[ "${#GH_TOKEN_ENV[@]}" -gt 0 ]]; then
    # Propagate git identity from host config so commits have proper author/email.
    git_name=$(git config --global user.name 2>/dev/null || true)
    git_email=$(git config --global user.email 2>/dev/null || true)
    [[ -n "$git_name" ]]  && GIT_AUTH_ENV+=(-e "GIT_AUTHOR_NAME=$git_name"    -e "GIT_COMMITTER_NAME=$git_name")
    [[ -n "$git_email" ]] && GIT_AUTH_ENV+=(-e "GIT_AUTHOR_EMAIL=$git_email"  -e "GIT_COMMITTER_EMAIL=$git_email")

    # Configure a credential helper that returns GH_TOKEN for github.com.
    # GIT_CONFIG_* vars are supported since git 2.32 (Ubuntu 22.04 ships 2.34).
    GIT_AUTH_ENV+=(
      -e "GIT_CONFIG_COUNT=1"
      -e "GIT_CONFIG_KEY_0=credential.https://github.com.helper"
      -e "GIT_CONFIG_VALUE_0=!f() { echo username=x-access-token; echo password=\$GH_TOKEN; }; f"
    )
  fi
fi

# Build extra mount args from .claude/sandbox/mounts JSON (optional).
# Format: {"defaults": [...], "custom": [...]}  each entry: "host_path" or "host_path:container_path"
EXTRA_MOUNTS=()
MOUNTS_FILE="$GIT_ROOT/.claude/sandbox/mounts"
# Relative paths in mounts are resolved against the main repo's parent directory,
# so ../foo works regardless of worktree layout.
MOUNTS_BASE="${MAIN_REPO_ROOT:-$GIT_ROOT}"
if [[ -f "$MOUNTS_FILE" ]]; then
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    if [[ "$entry" == *":"* ]]; then
      EXTRA_MOUNTS+=(-v "$entry")
    elif [[ "$entry" == ./* || "$entry" == ../* ]]; then
      [[ -d "$MOUNTS_BASE/$entry" ]] || continue
      resolved="$(cd "$MOUNTS_BASE" && cd "$entry" && pwd)"
      EXTRA_MOUNTS+=(-v "$resolved:$resolved")
    else
      EXTRA_MOUNTS+=(-v "$entry:$entry")
    fi
  done < <(jq -r '(.defaults + .custom)[]' "$MOUNTS_FILE")
fi

# Pre-accept the directory trust dialog for the container working directory.
# Claude checks ~/.claude.json (mounted into the container) for hasTrustDialogAccepted
# before reading project settings, so we write it here on the host before launching.
CLAUDE_JSON="$HOME/.claude.json"
if [[ -f "$CLAUDE_JSON" ]] && command -v jq &>/dev/null; then
  jq --arg p "/$DIRNAME" '.projects[$p].hasTrustDialogAccepted = true' "$CLAUDE_JSON" \
    > "$CLAUDE_JSON.tmp" && mv "$CLAUDE_JSON.tmp" "$CLAUDE_JSON"
fi

LOG_FILE="$GIT_ROOT/.claude/sandbox/sandbox.log"
{
  echo "=== $(date '+%Y-%m-%d %H:%M:%S') ==="
  echo "image:    $IMAGE"
  echo "workdir:  /$DIRNAME"
  echo "mounts:"
  echo "  $GIT_ROOT:/$DIRNAME"
  echo "  $HOME/.claude:/home/claude/.claude"
  echo "  $HOME/.claude.json:/home/claude/.claude.json"
  [[ "${#GH_TOKEN_ENV[@]}" -gt 0 ]] && echo "  GH_TOKEN: injected"
  [[ "${#GIT_AUTH_ENV[@]}" -gt 0 ]] && echo "  git identity+credential: injected"
  for m in "${WORKTREE_MOUNTS[@]}"; do [[ "$m" != "-v" ]] && echo "  $m (worktree)"; done
  for m in "${EXTRA_MOUNTS[@]}";    do [[ "$m" != "-v" ]] && echo "  $m (extra)";    done
  echo "claude args: ${PERM_ARGS[*]} $*"
  echo ""
} >> "$LOG_FILE"

exec docker run --rm -it \
  --platform linux/amd64 \
  -v "$GIT_ROOT:/$DIRNAME" \
  -v "$HOME/.claude:/home/claude/.claude" \
  -v "$HOME/.claude.json:/home/claude/.claude.json" \
  "${GH_TOKEN_ENV[@]+"${GH_TOKEN_ENV[@]}"}" \
  "${GIT_AUTH_ENV[@]+"${GIT_AUTH_ENV[@]}"}" \
  "${WORKTREE_MOUNTS[@]}" \
  "${EXTRA_MOUNTS[@]}" \
  -w "/$DIRNAME" \
  "$IMAGE" \
  claude "${PERM_ARGS[@]}" "$@"
