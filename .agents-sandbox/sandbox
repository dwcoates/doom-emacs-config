#!/usr/bin/env bash
# sandbox — unified launcher for AI coding tools inside the doom Docker sandbox.
# Installed as claude-sandbox and codex-sandbox; tool is derived from the invocation name.
# All arguments are forwarded transparently to the tool invocation.
#
# Extra mounts: edit .agents-sandbox/mounts (JSON with "defaults" and "custom" arrays).

set -euo pipefail

TOOL=$(basename "$0" | sed 's/-sandbox//')
GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) \
  || { echo "$TOOL-sandbox: not in a git repo" >&2; exit 1; }
DIRNAME=$(basename "$GIT_ROOT")
IMAGE=$("$GIT_ROOT/.agents-sandbox/run.sh" --image-name)

# ── tool-specific config ──────────────────────────────────────────────────────
case "$TOOL" in
  claude)
    TOOL_MOUNTS=(-v "$HOME/.claude:/home/claude/.claude"
                 -v "$HOME/.claude.json:/home/claude/.claude.json")
    TOOL_ENV=()
    GH_AUTH_VAR="CLAUDE_SANDBOX_GH_AUTH"
    PERM_OVERRIDE_FLAGS=(--permission-mode --dangerously-skip-permissions)
    PERM_ARGS_CHESSCM=(--permission-mode auto)
    PERM_ARGS_OTHER=(--dangerously-skip-permissions)
    ;;
  codex)
    TOOL_MOUNTS=(-v "$HOME/.codex:/home/claude/.codex")
    TOOL_ENV=()
    [[ -n "${OPENAI_API_KEY:-}" ]] && TOOL_ENV+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
    [[ -n "${OPENAI_BASE_URL:-}" ]] && TOOL_ENV+=(-e "OPENAI_BASE_URL=$OPENAI_BASE_URL")
    GH_AUTH_VAR="CODEX_SANDBOX_GH_AUTH"
    PERM_OVERRIDE_FLAGS=(--full-auto --dangerously-bypass-approvals-and-sandbox -a --ask-for-approval)
    PERM_ARGS_CHESSCM=(--full-auto)
    PERM_ARGS_OTHER=(--dangerously-bypass-approvals-and-sandbox)
    ;;
  *)
    echo "sandbox: unknown tool '$TOOL' (expected claude or codex)" >&2; exit 1 ;;
esac

# ── permission/approval mode ──────────────────────────────────────────────────
# Auto-detected from repo path unless caller already passed a flag.
HAS_PERM_FLAG=false
for arg in "$@"; do
  for flag in "${PERM_OVERRIDE_FLAGS[@]}"; do
    [[ "$arg" == "$flag" ]] && HAS_PERM_FLAG=true && break 2
  done
done

if [[ "$HAS_PERM_FLAG" == "false" ]]; then
  if [[ "$GIT_ROOT" == *"ChessCom"* ]]; then
    PERM_ARGS=("${PERM_ARGS_CHESSCM[@]}")
  else
    PERM_ARGS=("${PERM_ARGS_OTHER[@]}")
  fi
else
  PERM_ARGS=()
fi

# ── worktree mounts ───────────────────────────────────────────────────────────
# If running from a worktree, also mount the main repo so git's absolute
# references (in .git/worktrees/) resolve inside the container.
WORKTREE_MOUNTS=()
GIT_COMMON_DIR=$(git -C "$GIT_ROOT" rev-parse --git-common-dir 2>/dev/null || true)
if [[ -n "$GIT_COMMON_DIR" && "$GIT_COMMON_DIR" != ".git" ]]; then
  MAIN_REPO_ROOT=$(cd "$GIT_ROOT" && cd "$GIT_COMMON_DIR/.." && pwd)
  if [[ "$MAIN_REPO_ROOT" != "$GIT_ROOT" ]]; then
    WORKTREE_MOUNTS+=(-v "$MAIN_REPO_ROOT:$MAIN_REPO_ROOT")
  fi
fi

# ── GH token ─────────────────────────────────────────────────────────────────
# Opt-in via CLAUDE_SANDBOX_GH_AUTH=1 or CODEX_SANDBOX_GH_AUTH=1.
# Token sourced from ~/.config/gh/token, falling back to $GITHUB_TOKEN.
GH_TOKEN_ENV=()
GIT_INSTEADOF_ENV=()
if [[ -n "${!GH_AUTH_VAR:-}" ]]; then
  GH_TOKEN_FILE="$HOME/.config/gh/token"
  GH_TOKEN=""
  if [[ -f "$GH_TOKEN_FILE" ]]; then
    GH_TOKEN=$(cat "$GH_TOKEN_FILE")
  elif [[ -n "${GITHUB_TOKEN:-}" ]]; then
    GH_TOKEN="$GITHUB_TOKEN"
  else
    echo "$TOOL-sandbox: warning: $GH_AUTH_VAR is set but no token found (tried ~/.config/gh/token and \$GITHUB_TOKEN)" >&2
  fi
  if [[ -n "$GH_TOKEN" ]]; then
    GH_TOKEN_ENV=(-e "GH_TOKEN=$GH_TOKEN")
    # Rewrite SSH git URLs to HTTPS with the token so git fetch/push works
    # without SSH keys inside the container.
    GIT_INSTEADOF_ENV=(
      -e "GIT_CONFIG_COUNT=1"
      -e "GIT_CONFIG_KEY_0=url.https://x-access-token:${GH_TOKEN}@github.com/.insteadOf"
      -e "GIT_CONFIG_VALUE_0=git@github.com:"
    )
  fi
fi

# ── extra mounts ─────────────────────────────────────────────────────────────
# Reads .agents-sandbox/mounts — JSON {"defaults": [...], "custom": [...]}.
# Each entry: "host_path" or "host_path:container_path".
# Relative paths resolved against the main repo's parent so ../definitions
# works regardless of worktree layout.
EXTRA_MOUNTS=()
MOUNTS_FILE="$GIT_ROOT/.agents-sandbox/mounts"
MOUNTS_BASE="${MAIN_REPO_ROOT:-$GIT_ROOT}"
if [[ -f "$MOUNTS_FILE" ]]; then
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    if [[ "$entry" == *":"* ]]; then
      EXTRA_MOUNTS+=(-v "$entry")
    elif [[ "$entry" == ./* || "$entry" == ../* ]]; then
      [[ -d "$MOUNTS_BASE/$entry" ]] || continue
      resolved="$(cd "$MOUNTS_BASE" && cd "$entry" && pwd)"
      EXTRA_MOUNTS+=(-v "$resolved:$resolved")
    else
      EXTRA_MOUNTS+=(-v "$entry:$entry")
    fi
  done < <(jq -r '(.defaults + .custom)[]' "$MOUNTS_FILE")
fi

# ── claude: pre-accept trust dialog ──────────────────────────────────────────
if [[ "$TOOL" == "claude" ]]; then
  CLAUDE_JSON="$HOME/.claude.json"
  if [[ -f "$CLAUDE_JSON" ]] && command -v jq &>/dev/null; then
    jq --arg p "/$DIRNAME" '.projects[$p].hasTrustDialogAccepted = true' "$CLAUDE_JSON" \
      > "$CLAUDE_JSON.tmp" && mv "$CLAUDE_JSON.tmp" "$CLAUDE_JSON"
  fi
fi

# ── logging ───────────────────────────────────────────────────────────────────
LOG_FILE="$GIT_ROOT/.agents-sandbox/sandbox.log"
{
  echo "=== $(date '+%Y-%m-%d %H:%M:%S') ==="
  echo "tool:     $TOOL"
  echo "image:    $IMAGE"
  echo "workdir:  /$DIRNAME"
  echo "mounts:"
  echo "  $GIT_ROOT:/$DIRNAME"
  for m in "${TOOL_MOUNTS[@]}"; do [[ "$m" != "-v" ]] && echo "  $m"; done
  [[ "${#GH_TOKEN_ENV[@]}" -gt 0 ]] && echo "  GH_TOKEN: injected"
  [[ "${#GIT_INSTEADOF_ENV[@]}" -gt 0 ]] && echo "  git SSH->HTTPS rewrite: enabled"
  for m in "${WORKTREE_MOUNTS[@]}"; do [[ "$m" != "-v" ]] && echo "  $m (worktree)"; done
  for m in "${EXTRA_MOUNTS[@]}";    do [[ "$m" != "-v" ]] && echo "  $m (extra)";    done
  echo "$TOOL args: ${PERM_ARGS[*]-} $*"
  echo ""
} >> "$LOG_FILE"

DOCKER_IT=(-i); [ -t 0 ] && DOCKER_IT+=(-t)
exec docker run --rm "${DOCKER_IT[@]}" \
  --platform linux/amd64 \
  -v "$GIT_ROOT:/$DIRNAME" \
  "${TOOL_MOUNTS[@]}" \
  "${TOOL_ENV[@]+"${TOOL_ENV[@]}"}" \
  "${GH_TOKEN_ENV[@]+"${GH_TOKEN_ENV[@]}"}" \
  "${GIT_INSTEADOF_ENV[@]+"${GIT_INSTEADOF_ENV[@]}"}" \
  "${WORKTREE_MOUNTS[@]}" \
  "${EXTRA_MOUNTS[@]}" \
  -w "/$DIRNAME" \
  "$IMAGE" \
  "$TOOL" "${PERM_ARGS[@]}" "$@"
